      <reaction compartment="compartment_70101" fast="false" id="reaction_997309" metaid="metaid_114" name="Dephosphorylation of STAT1 by SHP2" reversible="false">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">SHP2 negatively regulates the IFN-induced JAK-STAT pathway by dephosphorylating STAT1 on Y701.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
