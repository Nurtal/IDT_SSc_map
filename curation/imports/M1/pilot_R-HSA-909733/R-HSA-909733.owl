    <listOfReactions>
      <reaction compartment="compartment_70101" fast="false" id="reaction_997311" metaid="metaid_92" name="Dephosphorylation of TYK2 by PTP1B" reversible="false">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">TYK2 bears the substrate recognition motif for PTP1B, and on IFN stimulation PTP1B interacts with and dephosphorylates TYK2.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
