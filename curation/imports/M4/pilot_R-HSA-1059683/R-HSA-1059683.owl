      <reaction compartment="compartment_876" fast="false" id="reaction_1112604" metaid="metaid_39" name="Phosphorylated STATs are released" reversible="false">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">Following phosphorylation, STATs are released from the receptor.</p>
        </notes>
        <annotation>
