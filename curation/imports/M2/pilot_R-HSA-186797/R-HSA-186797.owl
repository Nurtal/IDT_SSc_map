      <reaction compartment="compartment_70101" fast="false" id="reaction_186834" metaid="metaid_112" name="SOS-mediated nucleotide exchange on RAS (PDGF receptor:GRB2:SOS)" reversible="false">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">SOS is the guanine nucleotide exchange factor (GEF) for RAS. SOS activates RAS nucleotide exchange from the inactive form (bound to GDP) to an active form (bound to GTP).</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
